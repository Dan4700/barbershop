datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Роли пользователей
enum Role {
  USER
  ADMIN
}

// Модель Клиента
model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  name         String
  phone        String? // Номер телефона (опционально для регистрации)
  role         Role          @default(USER)
  appointments Appointment[] // Связь: у одного юзера много записей
  createdAt    DateTime      @default(now())
}

// Модель Мастера (Барбера)
model Master {
  id             Int           @id @default(autoincrement())
  name           String
  specialization String // Например, "Топ-барбер" или "Стажер"
  bio            String?
  appointments   Appointment[] // Связь: у одного мастера много записей
}

// Модель Услуги
model Service {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  price        Float // Цена услуги
  duration     Int // Длительность в минутах (например, 30, 60)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

// Модель Записи (Связующее звено)
model Appointment {
  id Int @id @default(autoincrement())

  // Время начала записи
  startTime DateTime

  // Кто записывается
  userId Int
  user   User @relation(fields: [userId], references: [id])

  // К кому записывается
  masterId Int
  master   Master @relation(fields: [masterId], references: [id])

  // На какую услугу (ЭТОГО НЕ БЫЛО РАНЬШЕ)
  serviceId Int
  service   Service @relation(fields: [serviceId], references: [id])

  status    String   @default("pending")
  createdAt DateTime @default(now())
}
