datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Роли пользователей
enum Role {
  USER
  ADMIN
}

// Модель Клиента
model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  name         String
  phone        String?       // Номер телефона (опционально для регистрации)
  role         Role          @default(USER)
  appointments Appointment[] // Связь: у одного юзера много записей
  createdAt    DateTime      @default(now())
}

// Модель Мастера (Барбера)
model Master {
  id             Int           @id @default(autoincrement())
  name           String
  specialization String        // Например, "Топ-барбер" или "Стажер"
  bio            String?
  appointments   Appointment[] // Связь: у одного мастера много записей
}

// Модель Записи (Связующее звено)
model Appointment {
  id        Int      @id @default(autoincrement())
  startTime DateTime // Время записи
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  master    Master   @relation(fields: [masterId], references: [id])
  masterId  Int
  status    String   @default("pending") // Например: pending, confirmed, cancelled
}